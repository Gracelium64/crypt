{
  "openapi": "3.0.0",
  "info": {
    "title": "Crypt Companion API",
    "version": "0.1.0",
    "description": "Minimal OpenAPI spec for local development and testing."
  },
  "servers": [{ "url": "http://localhost:4000/api" }],
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "Sign up",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "displayName": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/keys/register": {
      "post": {
        "summary": "Register public key",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/provider/link/init": {
      "post": {
        "summary": "Create LINK code",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/provider/link/status/{code}": {
      "get": {
        "summary": "Get LINK status",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/messages/send": {
      "post": {
        "summary": "Send message (requires linked provider)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
